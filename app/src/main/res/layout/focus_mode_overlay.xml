<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_mode_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- Align toggle button top-right -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp">

        <TextView
            android:id="@+id/focus_align_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:alpha="0.35"
            android:fontFamily="sans-serif-light"
            android:text="⇌"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </FrameLayout>

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/focus_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="8dp" />

    <!-- Bottom: presence dot + input -->
    <LinearLayout
        android:id="@+id/focus_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <View
            android:id="@+id/focus_presence_dot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="@drawable/focus_mode_dot"
            android:visibility="invisible" />

        <EditText
            android:id="@+id/focus_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:fontFamily="sans-serif-light"
            android:gravity="center"
            android:hint="Message"
            android:imeOptions="actionSend|flagNoEnterAction"
            android:inputType="text"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#44FFFFFF"
            android:textCursorDrawable="@null"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
