<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/focus_mode_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical">

    <!-- Align toggle top-right -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="40dp">

        <TextView
            android:id="@+id/focus_align_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:alpha="0.3"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="sans-serif-light"
            android:padding="8dp"
            android:text="⇌"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp" />

    </FrameLayout>

    <!-- RecyclerView + gradient fade overlay on top -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/focus_recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingBottom="8dp" />

        <!-- Gradient overlay: black at top fades to transparent at bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_gravity="top"
            android:background="@drawable/focus_mode_fade"
            android:importantForAccessibility="no" />

    </FrameLayout>

    <!-- Bottom: presence dot + input + send -->
    <LinearLayout
        android:id="@+id/focus_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp"
        android:paddingTop="8dp">

        <View
            android:id="@+id/focus_presence_dot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_gravity="center"
            android:layout_marginBottom="10dp"
            android:background="@drawable/focus_mode_dot"
            android:visibility="invisible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <EditText
                android:id="@+id/focus_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:hint="Message"
                android:imeOptions="flagNoEnterAction"
                android:inputType="text"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#44FFFFFF"
                android:textCursorDrawable="@null"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/focus_send_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:alpha="0.75"
                android:clickable="true"
                android:contentDescription="Send"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/symbol_send_fill_24"
                android:tint="#FFFFFFFF" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
